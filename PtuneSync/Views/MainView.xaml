<UserControl
    x:Class="PtuneSync.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:PtuneSync.Views">

    <Grid x:Name="RootGrid"
          Background="{ThemeResource SystemControlAcrylicWindowMediumHighBrush}"
          Padding="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- Commands -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
            <RowDefinition Height="*" />     <!-- Scrollable TaskEditor -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="PtuneSync"
                       FontSize="28"
                       FontWeight="SemiBold" />

            <Button Grid.Column="1"
                    Content="⋯"
                    x:Name="SettingsButton" />
        </Grid>

        <!-- Export / Reset -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    Margin="0,20,0,0">

            <Button Content="エクスポート"
                    Width="150"
                    Height="48"
                    Command="{Binding ExportCommand}" />

            <Button Content="リセット"
                    Width="150"
                    Height="48"
                    Command="{Binding ResetCommand}" />
        </StackPanel>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="8"
                CornerRadius="4"
                Margin="0,12,0,12">

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="14" />
        </Border>

        <!-- ★ ScrollViewer で TaskEditorView を囲む -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,0">

            <views:TaskEditorView  x:Name="TaskEditorHost"
                      Grid.Row="3" />
        </ScrollViewer>

    </Grid>
</UserControl>
